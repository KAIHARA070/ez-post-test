@{
    ViewData["Title"] = "Laman Utama";
}

<!-- Bahagian Hero (Pengenalan Utama) -->
<div class="text-center hero-section py-5 bg-primary text-white rounded shadow-sm mb-5">
    <h1 class="display-4 fw-bold">Sistem POS Paling Mudah & Stabil</h1>
    <p class="lead mt-3">Direka khas untuk kedai runcit kecil & sederhana tanpa kerumitan yang tidak perlu.</p>
    <a asp-controller="Home" asp-action="Pricing" class="btn btn-light btn-lg mt-3 fw-bold text-primary">Dapatkan Lesen Sekarang</a>
</div>

<!-- Bahagian Nilai Utama (Value Proposition) -->
<div class="row text-center mt-5">
    <div class="col-md-4 mb-4">
        <div class="card h-100 border-0 shadow-sm p-3">
            <h3 class="text-primary fw-bold">🚀 Pantas</h3>
            <h5 class="fw-bold mt-2">Lancar Segera</h5>
            <p>Aplikasi dilancarkan bawah 3 saat. Tiada lag atau kelewatan ketika melayan pelanggan.</p>
        </div>
    </div>
    <div class="col-md-4 mb-4">
        <div class="card h-100 border-0 shadow-sm p-3">
            <h3 class="text-primary fw-bold">✨ Mudah</h3>
            <h5 class="fw-bold mt-2">Antaramuka Bersih</h5>
            <p>UI yang ringkas dan kemas. Pekerja anda tidak perlukan latihan yang lama untuk mula menggunakannya.</p>
        </div>
    </div>
    <div class="col-md-4 mb-4">
        <div class="card h-100 border-0 shadow-sm p-3">
            <h3 class="text-primary fw-bold">🛡️ Stabil</h3>
            <h5 class="fw-bold mt-2">Tiada Kehilangan Data</h5>
            <p>Janji kami: Tiada crash. Tiada data hilang. Pangkalan data tempatan (SQLite) yang boleh dipercayai.</p>
        </div>
    </div>
</div>

<!-- Bahagian Info Tambahan -->
<div class="text-center mt-5 bg-light p-5 rounded">
    <h2 class="fw-bold">Bebas Internet & Peralatan Tambahan</h2>
    <p class="text-muted mt-3" style="max-width: 600px; margin: auto;">
        Sistem teras EZPos berfungsi sepenuhnya secara luar talian (offline). Walaupun pengimbas kod bar dan pencetak resit boleh disambungkan, ia bukanlah satu kemestian untuk anda mula menguruskan jualan.
    </p>
</div>

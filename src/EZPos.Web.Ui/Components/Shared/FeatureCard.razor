<FluentCard Class="feature-card">
    <div class="feature-icon">@Icon</div>
    <h3>@Title</h3>
    <p>@Description</p>
</FluentCard>

@code {
    [Parameter]
    public string Icon { get; set; } = "";

    [Parameter]
    public string Title { get; set; } = "";

    [Parameter]
    public string Description { get; set; } = "";
}

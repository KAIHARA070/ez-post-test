<FluentCard Class="@($"pricing-card {(IsFeatured ? "featured" : string.Empty)}")">
    @if (IsFeatured)
    {
        <FluentBadge Appearance="Appearance.Accent" Class="pricing-badge">Recommended</FluentBadge>
    }

    <h3>@PlanName</h3>
    <p class="plan-description">@PlanDescription</p>

    <div class="price-row">
        <span class="price">@Price</span>
        <span class="period">@Period</span>
    </div>

    <ul>
        @foreach (var item in Features)
        {
            <li>@item</li>
        }
    </ul>

    <FluentButton Appearance="@(IsFeatured ? Appearance.Accent : Appearance.Neutral)"
                  Href="@ActionHref"
                  Class="@($"pricing-action {(IsFeatured ? "btn-primary" : "btn-secondary")}")">
        @ActionText
    </FluentButton>
</FluentCard>

@code {
    [Parameter]
    public string PlanName { get; set; } = "";

    [Parameter]
    public string PlanDescription { get; set; } = "";

    [Parameter]
    public string Price { get; set; } = "";

    [Parameter]
    public string Period { get; set; } = "One-time";

    [Parameter]
    public bool IsFeatured { get; set; }

    [Parameter]
    public List<string> Features { get; set; } = new();

    [Parameter]
    public string ActionText { get; set; } = "Select Plan";

    [Parameter]
    public string ActionHref { get; set; } = "/pricing";
}

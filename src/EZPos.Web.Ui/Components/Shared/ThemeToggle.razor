@inject ThemeState ThemeState
@inject IJSRuntime JsRuntime

<FluentSwitch @bind-Value="isDark" OnChange="OnThemeChanged" Class="theme-toggle">
    @(isDark ? "Dark" : "Light")
</FluentSwitch>

@code {
    private bool isDark = true;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        isDark = await JsRuntime.InvokeAsync<bool>("ezTheme.applySaved");
        ThemeState.SetDarkMode(isDark);
        StateHasChanged();
    }

    private async Task OnThemeChanged(ChangeEventArgs args)
    {
        if (args.Value is bool value)
        {
            isDark = value;
        }
        else if (args.Value is string text && bool.TryParse(text, out var parsed))
        {
            isDark = parsed;
        }

        ThemeState.SetDarkMode(isDark);
        await JsRuntime.InvokeVoidAsync("ezTheme.set", isDark ? "dark" : "light");
    }
}

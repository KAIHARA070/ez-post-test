@page "/pricing"

<PageTitle>EZPos Pricing</PageTitle>

<section class="page-header">
    <p class="eyebrow">Pricing</p>
    <h1>Simple, transparent plans</h1>
    <p>Designed for one-time purchases now, structured for subscription tiers later.</p>
</section>

<section class="section-intro">
    <p class="eyebrow">Plan Guidance</p>
    <h2>Choose what fits your rollout stage</h2>
    <p>Start with Professional for immediate launch, then expand into Growth when branch operations and portal management are needed.</p>
</section>

<section class="pricing-row">
    <PricingCard
        PlanName="Professional License"
        PlanDescription="Ideal for most stores"
        Price="$199"
        Period="one-time"
        IsFeatured="true"
        Features="@ProFeatures"
        ActionText="Buy License"
        ActionHref="#" />

    <PricingCard
        PlanName="Growth Pack"
        PlanDescription="Planned expansion tier"
        Price="Coming Soon"
        Period="future"
        Features="@GrowthFeatures"
        ActionText="Notify Me"
        ActionHref="#" />
</section>

<section class="pricing-table-wrap">
    <table class="data-table" aria-label="EZPos plan comparison">
        <thead>
            <tr>
                <th>Capability</th>
                <th>Professional</th>
                <th>Growth</th>
            </tr>
        </thead>
        <tbody>
            <tr>
                <td>License model</td>
                <td>One-time</td>
                <td>Planned</td>
            </tr>
            <tr>
                <td>Validation API</td>
                <td class="status-success">Included</td>
                <td class="status-warning">Roadmap</td>
            </tr>
            <tr>
                <td>Portal readiness</td>
                <td class="status-success">Included</td>
                <td class="status-success">Included</td>
            </tr>
        </tbody>
    </table>
</section>

<section class="empty-state" aria-live="polite">
    <p class="eyebrow">Add-Ons</p>
    <h3>No optional add-ons available yet</h3>
    <p>
        We are preparing branch migration bundles and priority support packs.
        Core licensing remains fully available today.
    </p>
    <div class="empty-state-actions">
        <FluentButton Appearance="Appearance.Neutral" Class="btn-secondary" Href="#">Join Waitlist</FluentButton>
        <FluentButton Appearance="Appearance.Stealth" Class="btn-ghost" Href="/">Back to Overview</FluentButton>
    </div>
</section>

<section class="cta-strip compact">
    <h2>Need custom rollout support?</h2>
    <p>Talk to us for branch-based deployment and license operations planning.</p>
    <FluentButton Appearance="Appearance.Stealth" Class="btn-ghost" Href="/">Back to Home</FluentButton>
</section>

@code {
    private static readonly List<string> ProFeatures =
    [
        "Production-ready license flow",
        "Validation API integration",
        "Modern customer-facing UX"
    ];

    private static readonly List<string> GrowthFeatures =
    [
        "Multi-location support",
        "Admin controls",
        "Customer portal integration"
    ];
}

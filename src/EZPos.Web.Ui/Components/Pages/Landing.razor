@page "/"

<PageTitle>EZPos Landing</PageTitle>

<section class="landing-hero">
    <div class="hero-copy">
        <p class="eyebrow">EZPos License Key System</p>
        <h1>Professional POS licensing with a premium onboarding experience</h1>
        <p>
            A clean, Fluent-inspired customer journey for one-time licensing,
            ready to expand into dashboard and customer portal modules.
        </p>
        <div class="hero-actions">
            <FluentButton Appearance="Appearance.Accent" Href="/pricing">View Plans</FluentButton>
            <FluentButton Appearance="Appearance.Neutral" Href="/pricing">Explore Features</FluentButton>
        </div>
    </div>

    <FluentCard Class="hero-visual">
        <h3>Windows-like experience</h3>
        <p>Rounded surfaces, subtle elevation, smooth transitions, and dark mode by default.</p>
        <div class="visual-pills">
            <span>Acrylic Layers</span>
            <span>Fluent Components</span>
            <span>Future-ready Layout</span>
        </div>
    </FluentCard>
</section>

<section class="feature-grid">
    <FeatureCard
        Icon="01"
        Title="Fast Onboarding"
        Description="Simple flow from landing to checkout-ready plan selection." />
    <FeatureCard
        Icon="02"
        Title="Secure License Foundation"
        Description="Prepared for API-based key generation and online validation." />
    <FeatureCard
        Icon="03"
        Title="Dashboard Expansion"
        Description="Layout and component strategy built for customer portal growth." />
</section>

<section class="pricing-preview">
    <h2>One-time plans, enterprise-ready structure</h2>
    <div class="pricing-row">
        <PricingCard
            PlanName="Professional License"
            PlanDescription="For single business deployment"
            Price="$199"
            Period="one-time"
            IsFeatured="true"
            Features="@ProfessionalFeatures"
            ActionText="Select Professional"
            ActionHref="/pricing" />

        <PricingCard
            PlanName="Multi-Branch Pack"
            PlanDescription="Planned tier for multi-location rollouts"
            Price="Coming Soon"
            Period="future tier"
            Features="@EnterpriseFeatures"
            ActionText="Preview"
            ActionHref="/pricing" />
    </div>
</section>

<section class="cta-strip">
    <h2>Ready to launch EZPos licensing with confidence?</h2>
    <p>Start with a polished customer-facing foundation and expand without refactoring.</p>
    <FluentButton Appearance="Appearance.Accent" Href="/pricing">Get Started</FluentButton>
</section>

@code {
    private static readonly List<string> ProfessionalFeatures =
    [
        "One-time license",
        "Secure activation workflow",
        "Future customer portal ready"
    ];

    private static readonly List<string> EnterpriseFeatures =
    [
        "Centralized branch control",
        "Volume-friendly licensing",
        "Roadmap aligned"
    ];
}
@page "/Error"
@using System.Diagnostics

<PageTitle>Error</PageTitle>

<section class="error-panel page-header">
    <p class="eyebrow">System Error</p>
    <h1>An unexpected error occurred</h1>
    <p>Please retry the action. If the issue persists, contact support and share the request ID below.</p>

    @if (ShowRequestId)
    {
        <p>
            <strong>Request ID:</strong> <code>@RequestId</code>
        </p>
    }

    <h3>Development Note</h3>
    <p>
        Detailed exception content is only shown in <strong>Development</strong>. Keep production in <strong>Production</strong>
        to avoid exposing sensitive runtime data.
    </p>
</section>

@code{
    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    private string? RequestId { get; set; }
    private bool ShowRequestId => !string.IsNullOrEmpty(RequestId);

    protected override void OnInitialized() =>
        RequestId = Activity.Current?.Id ?? HttpContext?.TraceIdentifier;
}

@page
@model EZPos.Web.Api.Pages.SuccessModel
@{
    ViewData["Title"] = "Payment Successful";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="text-center mb-5">
                <div class="display-1 text-success mb-3">✓</div>
                <h1 class="mb-2">Payment Successful!</h1>
                <p class="lead text-muted">Your license key has been sent to your email.</p>
            </div>

            <div class="alert alert-info mb-4">
                <strong>Email:</strong> @Model.Success.Email
            </div>

            <div class="card mb-4">
                <div class="card-header bg-light">
                    <h5 class="mb-0">What's Next?</h5>
                </div>
                <div class="card-body">
                    <ol>
                        <li class="mb-3">
                            <strong>Check your email</strong> - Your license key and activation instructions have been sent to <strong>@Model.Success.Email</strong>
                        </li>
                        <li class="mb-3">
                            <strong>Download EZPos</strong> - Get the latest version from our download page
                        </li>
                        <li class="mb-3">
                            <strong>Activate your license</strong> - During installation, enter your license key when prompted
                        </li>
                        <li>
                            <strong>Start using EZPos</strong> - You're all set to manage your business!
                        </li>
                    </ol>
                </div>
            </div>

            <div class="card mb-4">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Troubleshooting</h5>
                </div>
                <div class="card-body">
                    <p><strong>Didn't receive an email?</strong></p>
                    <ul>
                        <li>Check your spam/junk folder</li>
                        <li><button type="button" class="btn btn-sm btn-link p-0" onclick="resendEmail()">Click here to resend</button></li>
                    </ul>
                </div>
            </div>

            <div class="d-grid gap-2 d-sm-flex justify-content-center">
                <a href="/" class="btn btn-outline-secondary btn-lg px-4">Back to Home</a>
                <a href="/pricing" class="btn btn-outline-primary btn-lg px-4">View Other Plans</a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function resendEmail() {
            alert("Resend functionality will be implemented in Phase 2");
        }
    </script>
}

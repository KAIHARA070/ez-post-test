@page
@model EZPos.Web.Api.Pages.PricingModel
@{
    ViewData["Title"] = "Pricing";
}

<div class="container py-5">
    <h1 class="text-center mb-2">@Model.Pricing.PageTitle</h1>
    <p class="text-center text-muted mb-5">@Model.Pricing.PageDescription</p>

    <div class="row">
        @foreach (var tier in Model.Pricing.Tiers)
        {
            <div class="col-md-6 col-lg-4 mb-4">
                <div class="card h-100 shadow-sm @(tier.IsRecommended ? "border-primary" : "")">
                    @if (tier.IsRecommended)
                    {
                        <div class="card-header bg-primary text-white text-center">
                            <span class="badge bg-danger">Recommended</span>
                        </div>
                    }
                    <div class="card-body">
                        <h5 class="card-title">@tier.Name</h5>
                        <p class="card-text text-muted">@tier.Description</p>
                        
                        <div class="mb-4">
                            <span class="display-6 fw-bold">$@tier.Price.ToString("0.00")</span>
                            <small class="text-muted">@tier.BillingPeriod</small>
                        </div>

                        <ul class="list-unstyled mb-4">
                            @foreach (var feature in tier.Features)
                            {
                                <li class="mb-2">
                                    <span class="text-success">✓</span> @feature
                                </li>
                            }
                        </ul>

                        <a href="/checkout" class="btn btn-primary w-100">Buy Now</a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<section class="py-5 bg-light">
    <div class="container">
        <h2 class="text-center mb-4">What's Included?</h2>
        <div class="row">
            <div class="col-md-3 text-center mb-3">
                <h5>Unlimited Users</h5>
                <p>Add as many team members as you need</p>
            </div>
            <div class="col-md-3 text-center mb-3">
                <h5>24/7 Support</h5>
                <p>Email and phone support always available</p>
            </div>
            <div class="col-md-3 text-center mb-3">
                <h5>Free Updates</h5>
                <p>Always get the latest features and fixes</p>
            </div>
            <div class="col-md-3 text-center mb-3">
                <h5>Money-Back Guarantee</h5>
                <p>30-day refund guarantee, no questions asked</p>
            </div>
        </div>
    </div>
</section>

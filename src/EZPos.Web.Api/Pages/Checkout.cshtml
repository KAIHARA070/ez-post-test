@page
@model EZPos.Web.Api.Pages.CheckoutModel
@{
    ViewData["Title"] = "Checkout";
}

<div class="container py-5">
    <div class="row">
        <div class="col-md-8">
            <h1 class="mb-4">Complete Your Purchase</h1>
            
            <form method="post" asp-page="Checkout" novalidate>
                <div class="card mb-4">
                    <div class="card-header bg-light">
                        <h5 class="mb-0">Order Summary</h5>
                    </div>
                    <div class="card-body">
                        <div class="row mb-3">
                            <div class="col">
                                <strong>EZPos Professional License</strong>
                                <p class="text-muted">One-time purchase</p>
                            </div>
                            <div class="col text-end">
                                <strong>$199.99</strong>
                            </div>
                        </div>
                        <hr />
                        <div class="row">
                            <div class="col">
                                <h5>Total</h5>
                            </div>
                            <div class="col text-end">
                                <h5>$199.99</h5>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card">
                    <div class="card-header bg-light">
                        <h5 class="mb-0">Your Information</h5>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label for="Email" class="form-label">Email Address</label>
                            <input type="email" class="form-control @(Model.Checkout != null && !string.IsNullOrEmpty(Model.Checkout.Email) ? "is-valid" : "")" 
                                   id="Email" name="Email" asp-for="Checkout.Email" placeholder="customer@example.com" required />
                            <span asp-validation-for="Checkout.Email" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label for="AgreeToTerms" class="form-check-label">
                                <input type="checkbox" class="form-check-input" id="AgreeToTerms" name="AgreeToTerms" required />
                                I agree to the <a href="#" target="_blank">Terms of Service</a> and <a href="#" target="_blank">Privacy Policy</a>
                            </label>
                            <span asp-validation-for="Checkout.AgreeToTerms" class="text-danger d-block"></span>
                        </div>

                        <button type="submit" class="btn btn-primary btn-lg w-100">
                            Proceed to Payment
                        </button>
                    </div>
                </div>
            </form>
        </div>

        <div class="col-md-4">
            <div class="card sticky-top" style="top: 20px;">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">Features Included</h5>
                </div>
                <div class="card-body">
                    <ul class="list-unstyled">
                        <li class="mb-2">✓ Unlimited transactions</li>
                        <li class="mb-2">✓ Multi-user support</li>
                        <li class="mb-2">✓ Inventory management</li>
                        <li class="mb-2">✓ Sales reporting</li>
                        <li class="mb-2">✓ Email support</li>
                        <li class="mb-2">✓ Regular updates</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
